# API server URL — 3DAIGC-API (https://github.com/AlfaOmegaGrafx/3DAIGC-API). Required for AI generation.
# Local default when you run the API on this machine (uvicorn, port 8000):
#   VITE_API_ENDPOINT=http://127.0.0.1:8000
# When the Vite dev server uses HTTPS (WebXR / Android WebView), http:// API URLs are blocked
# (mixed content + ERR_CLEARTEXT_NOT_PERMITTED). Use the dev proxy instead:
#   DEV_API_PROXY_TARGET=http://127.0.0.1:8000
#   VITE_API_ENDPOINT=/__dev_dgx_proxy
# Requests go to same-origin https://YOUR_PC:3000/__dev_dgx_proxy/... and Vite forwards to the target.
VITE_API_ENDPOINT=http://127.0.0.1:8000
# Real HTTP(S) API base for dev proxy only (not exposed to the client). Omit if not using /__dev_dgx_proxy.
DEV_API_PROXY_TARGET=

# Job status path for 3DAIGC-API / DGX Spark. App polls GET {apiEndpoint}/{path}/{jobId}. Required for job completion polling.
VITE_JOB_STATUS_PATH=api/v1/system/jobs

# When 3DAIGC-API has security.api_key_required, set Bearer token here (same value the backend expects after "Bearer ").
# VITE_3DAIGC_API_KEY=

# Longest side (px) for image-to-3D input before upload (default 2048; many APIs reject larger images).
# VITE_3DAIGC_MAX_IMAGE_SIDE=2048

VITE_ASSET_PATH=
VITE_OPENSEA_KEY=
VITE_HELIUS_KEY=
VITE_VALIDATION_SERVER_URL=http://localhost:3000

# Playwright MCP Bridge: set in env where Cursor runs so Playwright MCP can connect to the extension. Do not commit the real token.
# PLAYWRIGHT_MCP_EXTENSION_TOKEN=

# AvatarSDK integration (https://api.avatarsdk.com/)
# NOTE: For production, prefer exchanging OAuth tokens on your backend to avoid exposing client secret in browser builds.
VITE_AVATARSDK_CLIENT_ID=
VITE_AVATARSDK_CLIENT_SECRET=
# Optional: client mode isolation key (recommended per end-user/device).
VITE_AVATARSDK_PLAYER_UID=
# Optional defaults for avatar creation.
VITE_AVATARSDK_PIPELINE=metaperson_2.0
VITE_AVATARSDK_PIPELINE_SUBTYPE=male