# =============================================================================
# LOCAL DEVELOPMENT — copy to .env (gitignored). Never commit .env.
# =============================================================================
# See docs/PUBLIC_DEPLOY.md for Vercel / GitHub Pages (public demo uses fewer vars).

# API server URL — 3DAIGC-API (https://github.com/AlfaOmegaGrafx/3DAIGC-API). Required for AI generation locally.
# Local default when you run the API on this machine (uvicorn, port 8000):
#   VITE_API_ENDPOINT=http://127.0.0.1:8000
# When the Vite dev server uses HTTPS (WebXR / Android WebView), http:// API URLs are blocked
# (mixed content + ERR_CLEARTEXT_NOT_PERMITTED). Use the dev proxy instead:
#   DEV_API_PROXY_TARGET=http://127.0.0.1:8000
#   VITE_API_ENDPOINT=/__dev_dgx_proxy
# Requests go to same-origin https://YOUR_PC:3000/__dev_dgx_proxy/... and Vite forwards to the target.
VITE_API_ENDPOINT=http://127.0.0.1:8000
# Real HTTP(S) API base for dev proxy only (not exposed to the client). Omit if not using /__dev_dgx_proxy.
DEV_API_PROXY_TARGET=

# Job status path for 3DAIGC-API / DGX Spark. App polls GET {apiEndpoint}/{path}/{jobId}.
VITE_JOB_STATUS_PATH=api/v1/system/jobs

# LOCAL ONLY — embedded in client JS if set; do NOT add to Vercel for public demo.
# When 3DAIGC-API has security.api_key_required, set Bearer token here.
# VITE_3DAIGC_API_KEY=

# VITE_3DAIGC_MAX_IMAGE_SIDE=2048

# Loot: local bundle (default). Leave empty to use /loot-assets from npm run get-assets.
VITE_ASSET_PATH=

# Loot assets clone directory (default: ../loot-assets next to this repo). npm run get-assets links public/loot-assets.
# LOOT_ASSETS_EXTERNAL_DIR=C:\Users\alfao\Documents\GitHub\loot-assets

# Blockchain / minting (optional; keys are client-visible if prefixed VITE_)
VITE_OPENSEA_KEY=
VITE_HELIUS_KEY=
VITE_VALIDATION_SERVER_URL=http://localhost:3000

# Playwright MCP Bridge — Cursor host env only, not Vite client.
# PLAYWRIGHT_MCP_EXTENSION_TOKEN=

# AvatarSDK — LOCAL DEV ONLY. Never set VITE_AVATARSDK_CLIENT_SECRET on Vercel (ships in bundle).
VITE_AVATARSDK_CLIENT_ID=
VITE_AVATARSDK_CLIENT_SECRET=
VITE_AVATARSDK_PLAYER_UID=
VITE_AVATARSDK_PIPELINE=metaperson_2.0
VITE_AVATARSDK_PIPELINE_SUBTYPE=male

# =============================================================================
# PUBLIC DEPLOY (Vercel / GitHub Pages) — set in hosting dashboard only
# =============================================================================
# VITE_ASSET_PATH=https://m3-org.github.io/loot-assets/
# VITE_PUBLIC_DEMO=1
#
# Do NOT set on public hosting: VITE_3DAIGC_API_KEY, VITE_AVATARSDK_CLIENT_SECRET,
# VITE_THIRDWEB_SECRET_KEY, VITE_PINATA_*, VITE_ALCHEMY_API_KEY, private VITE_API_ENDPOINT.
# npm run build runs scripts/verify-public-build-env.mjs (strict on CI/Vercel).
