# Safe production / Vercel variables (copy to Vercel Project → Environment Variables).
# Do NOT copy .env here — local secrets must never ship in the client bundle.

# Public demo site (set in vercel.json by default)
VITE_PUBLIC_DEMO=1
VITE_ASSET_PATH=https://m3-org.github.io/loot-assets/

# Optional public client IDs (never secrets)
# VITE_THIRDWEB_CLIENT_ID=
# VITE_AVATARSDK_CLIENT_ID=

# Leave unset on Vercel unless you host a public HTTPS API:
# VITE_API_ENDPOINT=https://your-public-api.example.com
# VITE_JOB_STATUS_PATH=api/v1/system/jobs
