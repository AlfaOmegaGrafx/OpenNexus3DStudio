<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FACE_TRACKING" />
    <!-- WebView getUserMedia({ audio }) — lip sync / Web Audio input -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- WebView getUserMedia({ video }) — webcam / AR-style camera (optional but common with lip sync) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Optional: app runs on non-XR devices with Jetpack-only face. -->
    <uses-feature
        android:name="android.software.xr.api.openxr"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.OpenNexus3dStudioXrFaceBridge"
        android:usesCleartextTraffic="false">

        <!-- Android XR runtime broker (required for Khronos loader to resolve runtime on device). -->
        <uses-native-library
            android:name="libopenxr.google.so"
            android:required="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleInstance"
            android:hardwareAccelerated="true"
            android:supportsPictureInPicture="true"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode|density|fontScale">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".FaceKeeperActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:taskAffinity="com.opennexus3dstudio.xrfacebridge.keeper"
            android:theme="@style/Theme.FaceKeeper"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode|density|fontScale" />
        <service
            android:name=".FaceBridgeForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync|camera|microphone" />
    </application>
</manifest>
