{
  "name": "opennexus3dstudio",
  "version": "1.0.0",
  "description": "A 3D AIGC application for completely locally deployed and free 3DAIGC workflows",
  "homepage": "https://github.com/FishWoWater/OpenNexus3DStudio",
  "scripts": {
    "dev": "vite --host",
    "dev:iwsdk": "iwsdk dev up --open --foreground",
    "dev:runtime": "vite --host",
    "dev:vite": "vite --host",
    "dev:iwsdk:status": "iwsdk dev status",
    "dev:iwsdk:down": "iwsdk dev down",
    "iwsdk:adapter-sync": "iwsdk adapter sync",
    "iwsdk:adapter-status": "iwsdk adapter status",
    "iwsdk:adapter-prune": "iwsdk adapter prune",
    "iwsdk:reference-warmup": "iwsdk reference warmup",
    "iwsdk:reference-status": "iwsdk reference status",
    "iwsdk:mcp-inspect": "iwsdk mcp inspect",
    "iwsdk:scene-hierarchy": "iwsdk scene hierarchy",
    "iwsdk:ecs-systems": "iwsdk ecs systems",
    "iwsdk:ecs-find": "iwsdk ecs find",
    "iwsdk:xr-smoke": "node scripts/iwsdk-xr-smoke.mjs",
    "iwsdk:xr-deep-test": "node scripts/iwsdk-xr-deep-test.mjs",
    "playwright:install": "playwright install chromium",
    "get-assets": "node scripts/ensure-loot-assets.mjs",
    "build": "npm run get-assets && vite build",
    "serve": "vite preview",
    "dist-mac": "electron-builder --mac",
    "dist-win": "electron-builder --win",
    "dist-linux": "electron-builder --linux",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:anim-smoke": "node scripts/anim-playback-smoke.mjs",
    "test:appearance-smoke": "node scripts/appearance-loot-smoke.mjs",
    "test:appearance-browser": "node scripts/appearance-browser-smoke.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run lint:js && npm run lint:prettier",
    "lint:js": "eslint --cache --ext .js,.jsx ./src",
    "lint:prettier": "prettier --check \"**/*\" --end-of-line auto",
    "setup-mcp": "node scripts/setup-thirdweb-mcp.js",
    "setup-https": "node scripts/setup-https.js",
    "update-roadmap": "node scripts/update-roadmap-date.js"
  },
  "dependencies": {
    "@iwsdk/core": "^0.4.2",
    "@mediapipe/holistic": "^0.5.1675471629",
    "@pixiv/three-vrm": "^3.4.4",
    "@solana/web3.js": "^1.98.4",
    "@vitejs/plugin-react": "^4.7.0",
    "@web3-react/core": "^8.2.3",
    "@web3-react/injected-connector": "^6.0.7",
    "axios": "^1.8.0",
    "buffer": "^6.0.3",
    "classnames": "^2.5.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "electron": "^32.0.0",
    "ethers": "^6.16.0",
    "events": "^3.3.0",
    "express": "^5.2.1",
    "gsap": "^3.14.2",
    "html2canvas": "^1.4.1",
    "i18next": "^25.7.4",
    "kalidokit": "^1.1.5",
    "ktx2-encoder": "^0.5.1",
    "multer": "^2.0.2",
    "react": "^19.2.3",
    "react-color": "^2.19.3",
    "react-dom": "^19.2.3",
    "react-dropzone": "^14.2.3",
    "react-i18next": "^16.5.1",
    "react-router-dom": "^6.30.3",
    "react-select": "^5.10.2",
    "squaresplit": "^1.0.2",
    "styled-components": "^5.3.11",
    "thirdweb": "^5.116.1",
    "three": "^0.180.0",
    "three-mesh-bvh": "^0.9.10",
    "use-sound": "^5.0.0",
    "wait-on": "^7.2.0",
    "zustand": "^3.7.2"
  },
  "devDependencies": {
    "@iwsdk/cli": "^0.4.2",
    "@iwsdk/reference": "^0.4.2",
    "@iwsdk/vite-plugin-dev": "^0.4.2",
    "@playwright/test": "^1.58.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "electron-builder": "^25.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-no-inline-styles": "^1.0.5",
    "eslint-plugin-react": "^7.31.11",
    "jsdom": "^26.1.0",
    "prettier": "^2.8.8",
    "sass": "^1.97.2",
    "selfsigned": "^5.4.0",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.19.0 <21.0.0-0 || >=22.12.0 <23.0.0-0 || >=24.0.0"
  },
  "main": "public/electron.js",
  "build": {
    "appId": "com.opennexus3dstudio.app",
    "productName": "OpenNexus3DStudio",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "public/electron.js",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
